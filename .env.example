# Yahoo Fantasy Sports OAuth credentials (local dev only — never commit the real .env).
# In CI these are provided as GitHub Secrets of the same names.
# Obtain the consumer key/secret by registering an app at https://developer.yahoo.com/apps/
# The refresh token is produced on first yfpy OAuth login and reused for non-interactive runs.

YAHOO_CONSUMER_KEY=
YAHOO_CONSUMER_SECRET=
YAHOO_REFRESH_TOKEN=
